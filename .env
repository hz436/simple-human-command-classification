# ── Voice Command Pipeline — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.

# Path to the extracted Vosk model folder.
# Download from: https://alphacephei.com/vosk/models
#   Fast  (~40 MB) : vosk-model-small-en-us-0.15
#   Accurate (~1.8 GB): vosk-model-en-us-0.22
VOSK_MODEL_PATH=C:\models\vosk-model-small-en-us-0.15

# Path to your Edge Impulse trained.tflite file.
# This is already set to the default extraction path for this project.
TFLITE_MODEL_PATH=C:\models\human command classify\trained.tflite

# ── Edge Impulse project info (for reference only — not used at runtime) ──────
EDGE_IMPULSE_API_KEY=ei_74452541e90f0f7f33e6061c498dceb684be4b24860abc1f
EDGE_IMPULSE_PROJECT_ID=932661
